# NSP Plugin — Environment Variables
# Copy this file to .env and fill in your values

# --- Lightroom Catalog ---
# Absolute path to your Lightroom Classic catalog (.lrcat)
LIGHTROOM_CATALOG_PATH=/path/to/your/Lightroom Catalog.lrcat

# --- Server ---
# Port for the FastAPI inference server
NSP_SERVER_PORT=5678
NSP_SERVER_HOST=127.0.0.1

# --- Models ---
# Directory where trained models are stored
NSP_MODELS_DIR=models

# --- Training ---
# Number of preset clusters to identify (default: 4)
NSP_NUM_PRESETS=4
# Minimum star rating for photos used in training (default: 3)
NSP_MIN_RATING=3

# --- API Keys (optional) ---
# Only required if using remote LLM features
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
