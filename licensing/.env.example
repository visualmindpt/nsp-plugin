# NSP License Server - Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# DATABASE
# =============================================================================
# Development: SQLite (default)
DATABASE_URL=sqlite:///./nsp_licensing.db

# Production: PostgreSQL (recommended)
# DATABASE_URL=postgresql://user:password@localhost:5432/nsp_licenses

# =============================================================================
# JWT TOKEN SECRET
# =============================================================================
# Generate a secure random key for production:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-me-in-production

# =============================================================================
# ADMIN API KEY
# =============================================================================
# Used for admin endpoints (/api/v1/licenses/create, /api/v1/admin/stats)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_KEY=admin_secret_key_change_me

# =============================================================================
# STRIPE INTEGRATION
# =============================================================================
# Get these from: https://dashboard.stripe.com/apikeys

# Test mode (for development)
STRIPE_SECRET_KEY=your_stripe_test_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Live mode (for production - uncomment when ready)
# STRIPE_SECRET_KEY=your_stripe_live_secret_key_here
# STRIPE_WEBHOOK_SECRET=your_stripe_live_webhook_secret_here

# =============================================================================
# EMAIL (SendGrid)
# =============================================================================
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@vilearn.ai

# Alternative: If using different email provider
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Server host and port (Railway/Render will override these)
HOST=0.0.0.0
PORT=8080

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://vilearn.ai,https://www.vilearn.ai

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Sentry DSN (for error tracking in production - optional)
# SENTRY_DSN=https://xxxxxxx@sentry.io/xxxxxxx

# =============================================================================
# RATE LIMITING (optional)
# =============================================================================
# Max requests per minute per IP
RATE_LIMIT=60

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
#
# Railway:
# - Set these variables in Railway dashboard
# - DATABASE_URL is auto-configured when you add PostgreSQL
#
# Render:
# - Set in Environment section
# - Use PostgreSQL from Render database service
#
# cPanel (if using PHP):
# - Set in .htaccess or php.ini
# - Or use putenv() in checkout.php
#
# Docker:
# - Pass via docker-compose.yml or -e flags
# - Never commit .env to git!
#
