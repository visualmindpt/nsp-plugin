{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NSP-Control-Center",
  "version": "2.0.0",
  "identifier": "com.nsp.controlcenter",
  "build": {
    "frontendDist": "../static",
    "devUrl": "http://localhost:5033/dashboard",
    "beforeDevCommand": "cd ../.. && ./start_control_center.sh",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "NSP Control Center",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
